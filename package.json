{
    "name": "competitive-programming-helper",
    "displayName": "Competitive Programming Helper (cph)",
    "description": "Makes judging, compiling, and downloading problems for competitve programming easy. Also supports auto-submit for a few sites.",
    "license": "GPL-3.0-or-later",
    "icon": "icon.png",
    "publisher": "DivyanshuAgrawal",
    "version": "2077.0.0",
    "engines": {
        "vscode": "^1.52.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "*"
    ],
    "sponsor": {
        "url": "https://rb.gy/5iiorz"
    },
    "main": "dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "cph-judge-view-container",
                    "title": "%cph.judgeViewContainer.title%",
                    "icon": "dist/static/panel-view-icon.svg"
                }
            ]
        },
        "views": {
            "cph-judge-view-container": [
                {
                    "type": "webview",
                    "id": "cph.judgeView",
                    "name": "%cph.judgeView.name%"
                }
            ]
        },
        "commands": [
            {
                "command": "cph.runTestCases",
                "title": "%cph.runTestCases.title%",
                "icon": "dist/static/play.png"
            },
            {
                "command": "cph.submitToCodeForces",
                "title": "%cph.submitToCodeForces.title%",
                "icon": "dist/static/play.png"
            }
        ],
        "keybindings": [
            {
                "key": "ctrl+alt+b",
                "command": "cph.runTestCases"
            },
            {
                "key": "ctrl+alt+s",
                "command": "cph.submitToCodeForces"
            },
            {
                "key": "ctrl+alt+d",
                "command": "cph.judgeView.focus"
            }
        ],
        "configuration": {
            "title": "%cph.configuration.title%",
            "properties": {
                "cph.general.saveLocation": {
                    "type": "string",
                    "default": "",
                    "description": "%cph.general.saveLocation.description%"
                },
                "cph.general.timeOut": {
                    "type": "number",
                    "default": 3000,
                    "description": "%cph.general.timeOut.description%"
                },
                "cph.general.hideStderrorWhenCompiledOK": {
                    "type": "boolean",
                    "default": true,
                    "description": "%cph.general.hideStderrorWhenCompiledOK.description%"
                },
                "cph.general.ignoreSTDERROR": {
                    "type": "boolean",
                    "default": false,
                    "description": "%cph.general.ignoreSTDERROR.description%"
                },
                "cph.general.defaultOnlineJudge": {
                    "type": "boolean",
                    "default": false,
                    "description": "%cph.general.defaultOnlineJudge.description%"
                },
                "cph.language.c.Args": {
                    "title": "%cph.language.c.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.c.Args.description%"
                },
                "cph.language.c.SubmissionCompiler": {
                    "type": "string",
                    "default": "GNU GCC C11 5.1.0",
                    "enum": [
                        "GNU GCC C11 5.1.0"
                    ],
                    "description": "%cph.language.c.SubmissionCompiler.description%"
                },
                "cph.language.c.Command": {
                    "type": "string",
                    "default": "gcc",
                    "description": "%cph.language.c.Command.description%"
                },
                "cph.language.c.OutputArg": {
                    "type": "string",
                    "default": "-o",
                    "enum": [
                        "-o",
                        "/Fe:"
                    ],
                    "description": "%cph.language.c.OutputArg.description%"
                },
                "cph.language.cpp.Args": {
                    "title": "%cph.language.cpp.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.cpp.Args.description%"
                },
                "cph.language.cpp.SubmissionCompiler": {
                    "type": "string",
                    "default": "GNU G++23 14.2 (64 bit, msys2)",
                    "enum": [
                        "GNU G++17 7.3.0",
                        "GNU G++14 6.4.0",
                        "GNU G++11 5.1.0",
                        "GNU G++17 9.2.0 (64 bit, msys 2)",
                        "GNU G++20 13.2 (64 bit, winlibs)",
                        "GNU G++23 14.2 (64 bit, msys2)",
                        "Microsoft Visual C++ 2017",
                        "Microsoft Visual C++ 2010",
                        "Clang++17 Diagnostics"
                    ],
                    "description": "%cph.language.cpp.SubmissionCompiler.description%"
                },
                "cph.language.cpp.Command": {
                    "type": "string",
                    "default": "g++",
                    "description": "%cph.language.cpp.Command.description%"
                },
                "cph.language.cpp.OutputArg": {
                    "type": "string",
                    "default": "-o",
                    "enum": [
                        "-o",
                        "/Fe:"
                    ],
                    "description": "%cph.language.cpp.OutputArg.description%"
                },
                "cph.language.csharp.Args": {
                    "title": "%cph.language.csharp.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.csharp.Args.description%"
                },
                "cph.language.csharp.SubmissionCompiler": {
                    "type": "string",
                    "default": "C# 8, .NET Core 3.1",
                    "enum": [
                        "C# 8, .NET Core 3.1",
                        "C# 10, .NET SDK 6.0",
                        "C# Mono 6.8"
                    ],
                    "description": "%cph.language.csharp.SubmissionCompiler.description%"
                },
                "cph.language.csharp.Command": {
                    "type": "string",
                    "default": "dotnet",
                    "description": "%cph.language.csharp.Command.description%"
                },
                "cph.language.python.Args": {
                    "title": "%cph.language.python.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.python.Args.description%"
                },
                "cph.language.python.SubmissionCompiler": {
                    "type": "string",
                    "default": "PyPy 3.10 (7.3.15, 64bit)",
                    "enum": [
                        "PyPy 2.7 (7.2.0)",
                        "PyPy 3.6 (7.2.0)",
                        "PyPy 3.10 (7.3.15, 64bit)",
                        "Python 3.7.2",
                        "Python 2.7.15"
                    ],
                    "description": "%cph.language.python.SubmissionCompiler.description%"
                },
                "cph.language.python.Command": {
                    "type": "string",
                    "default": "python3",
                    "description": "%cph.language.python.Command.description%"
                },
                "cph.language.ruby.Args": {
                    "title": "%cph.language.ruby.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.ruby.Args.description%"
                },
                "cph.language.ruby.SubmissionCompiler": {
                    "type": "string",
                    "default": "Ruby 3.2.2",
                    "enum": [
                        "Ruby 3.2.2"
                    ],
                    "description": "%cph.language.ruby.SubmissionCompiler.description%"
                },
                "cph.language.ruby.Command": {
                    "type": "string",
                    "default": "ruby",
                    "description": "%cph.language.ruby.Command.description%"
                },
                "cph.language.rust.Args": {
                    "title": "%cph.language.rust.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.rust.Args.description%"
                },
                "cph.language.rust.SubmissionCompiler": {
                    "type": "string",
                    "default": "Rust 1.75.0 (2021)",
                    "enum": [
                        "Rust 1.75.0 (2021)"
                    ],
                    "description": "%cph.language.rust.SubmissionCompiler.description%"
                },
                "cph.language.rust.Command": {
                    "type": "string",
                    "default": "rustc",
                    "description": "%cph.language.rust.Command.description%"
                },
                "cph.language.go.Args": {
                    "title": "%cph.language.go.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.go.Args.description%"
                },
                "cph.language.go.SubmissionCompiler": {
                    "type": "string",
                    "default": "Go 1.22.2",
                    "enum": [
                        "Go 1.22.2"
                    ],
                    "description": "%cph.language.go.SubmissionCompiler.description%"
                },
                "cph.language.go.Command": {
                    "type": "string",
                    "default": "go",
                    "description": "%cph.language.go.Command.description%"
                },
                "cph.language.haskell.Args": {
                    "title": "%cph.language.haskell.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.haskell.Args.description%"
                },
                "cph.language.haskell.SubmissionCompiler": {
                    "type": "string",
                    "default": "Haskell GHC 8.10.1",
                    "enum": [
                        "Haskell GHC 8.10.1"
                    ],
                    "description": "%cph.language.haskell.SubmissionCompiler.description%"
                },
                "cph.language.haskell.Command": {
                    "type": "string",
                    "default": "ghc",
                    "description": "%cph.language.haskell.Command.description%"
                },
                "cph.language.java.Args": {
                    "title": "%cph.language.java.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.java.Args.description%"
                },
                "cph.language.java.SubmissionCompiler": {
                    "type": "string",
                    "default": "Java 21 64bit",
                    "enum": [
                        "Java 21 64bit",
                        "Java 11.0.6",
                        "Java 8 32bit"
                    ],
                    "description": "%cph.language.java.SubmissionCompiler.description%"
                },
                "cph.language.java.Command": {
                    "type": "string",
                    "default": "javac",
                    "description": "%cph.language.java.Command.description%"
                },
                "cph.language.js.Args": {
                    "title": "%cph.language.js.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.js.Args.description%"
                },
                "cph.language.js.SubmissionCompiler": {
                    "type": "string",
                    "default": "Node.js 15.8.0 (64bit)",
                    "enum": [
                        "Node.js 15.8.0 (64bit)",
                        "JavaScript V8 4.8.0"
                    ],
                    "description": "%cph.language.js.SubmissionCompiler.description%"
                },
                "cph.language.js.Command": {
                    "type": "string",
                    "default": "node",
                    "description": "%cph.language.js.Command.description%"
                },
                "cph.language.cangjie.Args": {
                    "title": "%cph.language.cangjie.Args.title%",
                    "type": "string",
                    "default": "",
                    "description": "%cph.language.cangjie.Args.description%"
                },
                "cph.language.cangjie.Command": {
                    "type": "string",
                    "default": "cjc",
                    "description": "%cph.language.cangjie.Command.description%"
                },
                "cph.general.firstTime": {
                    "title": "%cph.general.firstTime.title%",
                    "type": "boolean",
                    "default": true,
                    "description": "%cph.general.firstTime.description%"
                },
                "cph.general.defaultLanguage": {
                    "title": "%cph.general.defaultLanguage.title%",
                    "type": "string",
                    "default": "",
                    "enum": [
                        "none",
                        "c",
                        "cpp",
                        "python",
                        "rust",
                        "js",
                        "java",
                        "ruby",
                        "csharp",
                        "go",
                        "haskell",
                        "cangjie"
                    ],
                    "description": "%cph.general.defaultLanguage.description%"
                },
                "cph.general.menuChoices": {
                    "type": "string",
                    "default": "cpp java js python c rust ruby csharp go haskell",
                    "description": "%cph.general.menuChoices.description%"
                },
                "cph.general.includeProblemIndex": {
                    "type": "boolean",
                    "default": false,
                    "description": "Include the problem index for problem file generated ( like P_1_abc ) instead of omitting it"
                },
                "cph.general.wordRegex": {
                    "type": "string",
                    "default": "[\\p{L}]+|[0-9]+",
                    "description": "The regex that defines what a word is for problem file generated. Each word is separated by an underscore"
                },
                "cph.general.useShortCodeForcesName": {
                    "type": "boolean",
                    "default": false,
                    "description": "%cph.general.useShortCodeForcesName.description%"
                },
                "cph.general.useShortLuoguName": {
                    "type": "boolean",
                    "default": false,
                    "description": "%cph.general.useShortLuoguName.description%"
                },
                "cph.general.useShortAtCoderName": {
                    "type": "boolean",
                    "default": false,
                    "description": "%cph.general.useShortAtCoderName.description%"
                },
                "cph.general.retainWebviewContext": {
                    "type": "boolean",
                    "default": false,
                    "description": "%cph.general.retainWebviewContext.description%"
                },
                "cph.general.defaultLanguageTemplateFileLocation": {
                    "type": "string",
                    "default": "",
                    "description": "%cph.general.defaultLanguageTemplateFileLocation.description%"
                },
                "cph.general.doTemplateFileVariableReplacement": {
                    "type": "boolean",
                    "default": false,
                    "description": "Replace $var$ in the template file with its value. For example, replace $url$ with the problem's url. For a full list, see what is outputted in the console with debug mode on for Competitive Companion"
                },
                "cph.general.autoShowJudge": {
                    "type": "boolean",
                    "default": true,
                    "description": "%cph.general.autoShowJudge.description%"
                },
                "cph.general.remoteServerAddress": {
                    "type": "string",
                    "default": "http://20.244.105.138:4546",
                    "description": "%cph.general.remoteServerAddress.description%"
                },
                "cph.general.showLiveUserCount": {
                    "type": "boolean",
                    "default": false,
                    "description": "%cph.general.showLiveUserCount.description%"
                }
            }
        }
    },
    "scripts": {
        "webpack-production": "webpack --mode production",
        "webpack-frontend-production": "webpack --mode production --config ./webpack.frontend.config.js",
        "vscode:prepublish": "npm run webpack-frontend-production && npm run webpack-production",
        "prewebpack": "webpack --mode development --config ./webpack.frontend.config.js",
        "webpack": "webpack --mode development",
        "webpack-dev": "webpack --mode development --watch",
        "webpack-frontend-dev": "webpack --mode development --watch --config ./webpack.frontend.config.js",
        "test-compile": "tsc -p ./",
        "lint": "eslint . --ext .ts,.tsx",
        "pretest": "tsc -p ./",
        "test": "jest out/ --silent=false"
    },
    "devDependencies": {
        "@types/jest": "^29.5.10",
        "@types/node": "^20.9.5",
        "@types/react": "^18.2.38",
        "@types/react-dom": "^18.2.17",
        "@types/vscode": "^1.52.0",
        "@typescript-eslint/eslint-plugin": "^6.12.0",
        "@typescript-eslint/parser": "^6.12.0",
        "@vscode/codicons": "^0.0.35",
        "copy-webpack-plugin": "^11.0.0",
        "eslint": "^8.54.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.1",
        "eslint-plugin-react": "^7.33.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "jest": "^29.7.0",
        "prettier": "3.1.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.3.2",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "@vscode/extension-telemetry": "^0.9.0",
        "ansi-to-html": "^0.7.2",
        "python-shell": "^5.0.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-textarea-autosize": "^8.5.3",
        "vscode-nls": "^5.2.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/agrawal-d/competitive-programming-helper/"
    }
}
